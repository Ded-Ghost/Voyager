# ── Required ──────────────────────────────────────────
# Get your free key at: console.groq.com → API Keys
GROQ_API_KEY=your_groq_key_here

# Model — llama-3.3-70b-versatile is recommended (best tool use)
# Other options: llama3-groq-70b-8192-tool-use-preview, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# ── Dashboard ─────────────────────────────────────────
DASHBOARD_PORT=7777
AUTO_OPEN_DASHBOARD=true

# ── Voice ─────────────────────────────────────────────
# System TTS off by default — the browser dashboard uses Web Speech API
# which has much better neural voices (Microsoft Aria, Jenny, etc.)
# Set TTS_ENABLED=true ONLY if you run headless without the dashboard.
TTS_ENABLED=false

# ── Optional — enriches live data (all free tiers) ───
TICKETMASTER_API_KEY=
AVIATIONSTACK_API_KEY=

# ── Paths ─────────────────────────────────────────────
ITINERARY_DIR=./itineraries

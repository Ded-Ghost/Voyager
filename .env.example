# ── Required ──────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here

# ── Dashboard ─────────────────────────────────────────
DASHBOARD_PORT=7777
AUTO_OPEN_DASHBOARD=true

# ── Voice ─────────────────────────────────────────────
# Set TTS_ENABLED=false to disable voice output at boot
TTS_ENABLED=true

# ── Optional API keys (free tiers, enriches data) ────
TICKETMASTER_API_KEY=
AVIATIONSTACK_API_KEY=

# ── Paths ─────────────────────────────────────────────
ITINERARY_DIR=./itineraries

# ═══════════════════════════════════════════════════════
# VOYAGER India — Environment Configuration
# ═══════════════════════════════════════════════════════

# ─── AI API (pick one) ───────────────────────────────
# RECOMMENDED: Google Gemini 2.0 Flash — completely FREE
# Get your key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# FALLBACK: Groq (also free tier available)
# Get your key: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─── APP CONFIG ──────────────────────────────────────
DASHBOARD_PORT=7777
AUTO_OPEN_DASHBOARD=true
TTS_ENABLED=true

# ─── INDIA FOCUS ─────────────────────────────────────
DEFAULT_COUNTRY=India
PRIMARY_AIRPORTS=DEL,BOM,BLR,MAA,CCU,HYD,COK,AMD,PNQ,GOI
